PRIMARY_DEST_TYPE{0} XLSXW
PRIMARY_DEST_KEYWORD{0} XLSXW_1
PRIMARY_DEST_GEN_DIRECTIVES{0} FIELD_NAMES_VERTICAL_ALIGNMENT,<lt>Unused<gt>,DESTINATION_DATASETTYPE_VALIDATION,Yes,TEMPLATE_SHEET,,FIELD_NAMES_FILL,<lt>Unused<gt>,FIELD_NAMES_PATTERN_STYLE,<lt>Unused<gt>,REMOVE_UNCHANGED_TEMPLATE_SHEET,No,FIELD_NAMES_PATTERN_COLOR,<lt>Unused<gt>,FIELD_NAMES_FONT_NAME,<lt>Unused<gt>,FIELD_NAMES_TEXT_ALIGNMENT,<lt>Unused<gt>,FIELD_NAMES_TEXT_CONTROL,<lt>Unused<gt>,FIELD_NAMES_OUT,Yes,FIELD_NAMES_FORMATTING,NO,STRICT_SCHEMA_ADDITIONAL_ATTRIBUTE_MATCHING,yes,PROTECT_SHEET,NO,TEMPLATEFILE,,WRITER_MODE,Insert,FIELD_NAMES_CELL_BORDER_STYLE,<lt>Unused<gt>,FIELD_NAMES_BACKGROUND_COLOR,<lt>Unused<gt>,MULTIPLE_TEMPLATE_SHEETS,Yes,FIELD_NAMES_CELL_BORDER_COLOR,<lt>Unused<gt>,FIELD_NAMES_TEXT_INDENT,<lt>Unused<gt>,FIELD_NAMES_TEXT_ORIENTATION,<lt>Unused<gt>,INSERT_IGNORE_DB_OP,Yes,PROTECT_SHEET_LEVEL,<lt>Unused<gt>,FIELD_NAMES_CELL_BORDER,<lt>Unused<gt>,OVERWRITE_FILE,No,RASTER_FORMAT,PNG,CUSTOM_NUMBER_FORMATTING,ENABLE_NATIVE,TRUNCATE_TABLE,No,ADD_WRITER_NEXT_ACTION,automatic,FIELD_NAMES_FONT,<lt>Unused<gt>,FIELD_NAMES_ROW_HEIGHT,<lt>Unused<gt>,DROP_TABLE,No,PROTECT_SHEET_PASSWORD,<lt>Unused<gt>,FIELD_NAMES_FONT_COLOR,<lt>Unused<gt>,FIELD_NAMES_HORIZONTAL_ALIGNMENT,<lt>Unused<gt>,PROTECT_SHEET_PERMISSIONS,<lt>Unused<gt>,ALWAYS_CREATE_FEATURE_TYPES,NO,COORDINATE_SYSTEM_GRANULARITY,FEATURE
