INCLUDE [ if {{$(Start_date$encode)} == {}} { puts_real {Parameter 'Start_date' must be given a value.}; exit 1; }; ]
INCLUDE [ if {{$(end_date$encode)} == {}} { puts_real {Parameter 'end_date' must be given a value.}; exit 1; }; ]
