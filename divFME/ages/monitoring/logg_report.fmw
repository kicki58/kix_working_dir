MACRO SQLCreator_DIRECTIVES CREATE_FEATURE_TABLES_FROM_DATA Yes NAMED_CONNECTION "$(PostgreSQL_CONNECTION)" QUERY_FEATURE_TYPES_FOR_MERGE_FILTERS Yes READ_TIME_WITH_TIMEZONE Yes SCHEMAS_FOR_TABLE_LISTING ""
FACTORY_DEF {*} CreationFactory    FACTORY_NAME { SQLCreator_Creator }    OUTPUT { FEATURE_TYPE _____CREATED______ }
FACTORY_DEF {*} QueryFactory    FACTORY_NAME { SQLCreator }    INPUT FEATURE_TYPE _____CREATED______    QUERY_SQL            { FME_SQL_DELIMITER<space><semicolon><lf>SELECT<space>operation<comma><space>count<openparen>operation<closeparen><space><lf>FROM<space>logs.geoserver<lf>where<space>starttime<space><gt>=<space>to_date<openparen><apos>$(Start_date$encode)<apos><comma><space><apos>YYYYMMDD<apos><closeparen><space>AND<space>endtime<space><lt><space>to_date<openparen><apos>$(end_date$encode)<apos><comma><space><apos>YYYYMMDD<apos><closeparen><lf>group<space>by<space>operation<space><lf> }    COMBINE_ATTRIBUTES   RESULT_ONLY    COMBINE_GEOMETRY     RESULT_ONLY    READER_TYPE          { POSTGRES   }    READER_DATASET       { "$(PostgreSQL_CONNECTION)" }    READER_PARAMS        { $(SQLCreator_DIRECTIVES) }    QUERYFCT_OUTPUT      { "DATA_ONLY" }    QUERYFCT_PROPAGATE_IDS_ON_SQL_EXECUTE YES    CONTINUE_ON_READER_ERROR YES    TREAT_READER_PARAM_AMPERSANDS_AS_LITERALS YES    OUTPUT { RESULT FEATURE_TYPE SQLCreator_RESULT        @SupplyAttributes(fme_feature_type,SQLCreator)         }
FACTORY_DEF * BranchingFactory   FACTORY_NAME "SQLCreator_RESULT Brancher -1 32"   INPUT FEATURE_TYPE SQLCreator_RESULT   TARGET_FACTORY "$(WB_CURRENT_CONTEXT)_CREATOR_BRANCH_TARGET"   MAXIMUM_COUNT None   OUTPUT PASSED FEATURE_TYPE *
