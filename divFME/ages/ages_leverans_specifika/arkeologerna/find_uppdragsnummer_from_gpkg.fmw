MACRO FeatureReader_2_OUTPUT_PORTS_ENCODED 
MACRO FeatureReader_2_DIRECTIVES ADVANCED_GROUP,FME_DISCLOSURE_OPEN,ENCODE_FEATURE_TYPE_AND_ATTR_NAMES,YES,ENFORCE_FOREIGN_KEY_INTEGRITY,YES,EXPOSE_ATTRS_GROUP,FME_DISCLOSURE_OPEN,EXPOSE_PRIMARY_KEY_ATTRIBUTE,YES,NETWORK_AUTHENTICATION,,OGCGEOPACKAGE_EXPOSE_FORMAT_ATTRS,,OPEN_SINGLE_RASTER_AS_SUBDATASET,YES,QUERY_FEATURE_TYPES_FOR_MERGE_FILTERS,Yes,READ_BOOLEANS_AS_YES_NO,YES,READ_NULLS,YES,READER_REPLACE_INVALID_CHARS,NO,TABLELIST,,USE_SEARCH_ENVELOPE,NO
