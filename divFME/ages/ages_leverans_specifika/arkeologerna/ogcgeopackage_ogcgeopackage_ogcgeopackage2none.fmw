FACTORY_DEF {*} AttributeKeeperFactory    FACTORY_NAME { AttributeKeeper }    INPUT  FEATURE_TYPE dublett_OGCGEOPACKAGE_3    KEEP_ATTRS { arkeologenrna_lst<space>dnr,arkeologenrna_path_rootname,diarienummer,dublett_arkeologenrna_lst<space>dnr,dublett_arkeologenrna_path_rootname,dublett_diarienummer,uppdragsnummer }    KEEP_LISTS {  }    KEEP_FME_ATTRIBUTES Yes    BUILD_FEATURE_TABLES { NO }    OUTPUT_ON_ATTRIBUTE_CHANGE { <Unused> }    OUTPUT { OUTPUT FEATURE_TYPE AttributeKeeper_OUTPUT        }
# -------------------------------------------------------------------------
# 20210313 - Use Macros to engage/disengage the solid vs. 2d buffering rather than a runtime
# check to reduce processing overhead
INCLUDE [if { ("JOIN_ARC" == "JOIN_MITER") } {         } else {             puts "MACRO MITER_TO_USE 0"         };         if { ("AREA" == "SOLID") } {             puts "MACRO SOLIDFACTORYENGAGED *";             puts "MACRO DISSOLVEFACTORYENGAGED NO";         } else {             puts "MACRO SOLIDFACTORYENGAGED NO";             puts "MACRO DISSOLVEFACTORYENGAGED *";         };         ]
#
# This is the AREA part of the buffering:
#
