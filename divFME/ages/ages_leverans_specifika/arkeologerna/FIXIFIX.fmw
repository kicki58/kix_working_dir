DEFAULT_MACRO WB_CURRENT_CONTEXT
# -------------------------------------------------------------------------
# Build the List removal function and regular expression if there was any list attributes to be removed.
# If not, then we will not have any extra list removal call to @RemoveAttributes, which speeds the
# normal, non-list removal especially when in Bulk Mode.  Note that this computation of the regular expressions is done
# once during mapping file parse time.
INCLUDE [    set listAttributeRemoveRegexps {};    set anyList {no};    foreach attr [split ""] {       set attr [FME_DecodeText $attr];       set attr [regsub "{}$" $attr "{}.*"];       set attr [regsub -all "{}" $attr "\\{\[0-9\]+\\}"];       append listAttributeRemoveRegexps ",^$attr$";       set anyList {yes};    };    if { ${anyList} == {no} } {        puts {MACRO AttributeRemover_LIST_FUNC }    } else {        puts "MACRO AttributeRemover_LIST_FUNC @RemoveAttributes(fme_pcre_match\"$listAttributeRemoveRegexps\")"    }; ]
FACTORY_DEF {*} TeeFactory    FACTORY_NAME { AttributeRemover }    INPUT  FEATURE_TYPE project_information_OGCGEOPACKAGE_2_0_DqXXLsqo22o=    OUTPUT { FEATURE_TYPE AttributeRemover_OUTPUT        @RemoveAttributes(fme_encoded,beskrivning,exploateringstyp,id,inventarienummer,lst<space>dnr,pk,plats,projektkod,projektledare,projektnamn,ra<u00e4><space>dnr,slutdatum,unders<u00f6>kningstyp,uppdragsgivare,siteid)        $(AttributeRemover_LIST_FUNC)         }
# -------------------------------------------------------------------------
FACTORY_DEF {*} TeeFactory    FACTORY_NAME { AttributeFilter_2 }    INPUT  FEATURE_TYPE PATH_PATH_1    OUTPUT { FEATURE_TYPE AttributeFilter_2_FILTER }
FACTORY_DEF {*} AttributeFilterFactory FACTORY_NAME AttributeFilter_2_Filter COMMAND_PARM_EVALUATION SINGLE_PASS INPUT FEATURE_TYPE AttributeFilter_2_FILTER FILTER_ATTRIBUTE { path_rootname } FILTER_VALUES { <lt>EMPTY<gt> <lt>MISSING<gt> <lt>NULL<gt> <lt>UNFILTERED<gt> agg_uppdragsnummer aggregated_intrasis aggregated aggregated_reprojected jmfr4 } PRESERVE_FEATURE_ORDER PER_OUTPUT_PORT OUTPUT <lt>EMPTY<gt> FEATURE_TYPE AttributeFilter_2_<lt>EMPTY<gt> OUTPUT <lt>MISSING<gt> FEATURE_TYPE AttributeFilter_2_<lt>MISSING<gt> OUTPUT <lt>NULL<gt> FEATURE_TYPE AttributeFilter_2_<lt>NULL<gt> OUTPUT <lt>UNFILTERED<gt> FEATURE_TYPE AttributeFilter_2_<lt>UNFILTERED<gt> OUTPUT agg_uppdragsnummer FEATURE_TYPE AttributeFilter_2_agg_uppdragsnummer OUTPUT aggregated_intrasis FEATURE_TYPE AttributeFilter_2_aggregated_intrasis OUTPUT aggregated FEATURE_TYPE AttributeFilter_2_aggregated OUTPUT aggregated_reprojected FEATURE_TYPE AttributeFilter_2_aggregated_reprojected OUTPUT jmfr4 FEATURE_TYPE AttributeFilter_2_jmfr4
