# in a macro, which is then used to define the dataset to be written.
GUI MULTIFILE DestDataset_OGCGEOPACKAGE_3 GeoPackage_Files(*.gpkg)|*.gpkg|All_files(*)|* GeoPackage File:
DEFAULT_MACRO OGCGEOPACKAGE_OUT_FME_CONNECTION_GROUP_OGCGEOPACKAGE_3 
GUI OPTIONAL DISCLOSUREGROUP OGCGEOPACKAGE_OUT_FME_CONNECTION_GROUP_OGCGEOPACKAGE_3 OGCGEOPACKAGE_OUT_NAMED_CONNECTION%OGCGEOPACKAGE_OUT_OVERWRITE_DATASET_OGCGEOPACKAGE_3%OGCGEOPACKAGE_OUT_DATASET_TEMPLATE_OGCGEOPACKAGE_3 Database Connection
DEFAULT_MACRO OGCGEOPACKAGE_OUT_OVERWRITE_DATASET_OGCGEOPACKAGE_3 NO
OGCGEOPACKAGE_3_OVERWRITE_DATASET "$(OGCGEOPACKAGE_OUT_OVERWRITE_DATASET_OGCGEOPACKAGE_3)"
GUI OPTIONAL ACTIVECHECK OGCGEOPACKAGE_OUT_OVERWRITE_DATASET_OGCGEOPACKAGE_3 YES%NO,OGCGEOPACKAGE_OUT_DATASET_TEMPLATE_OGCGEOPACKAGE_3 Overwrite Existing Database:
DEFAULT_MACRO OGCGEOPACKAGE_OUT_DATASET_TEMPLATE_OGCGEOPACKAGE_3 
OGCGEOPACKAGE_3_DATASET_TEMPLATE "$(OGCGEOPACKAGE_OUT_DATASET_TEMPLATE_OGCGEOPACKAGE_3)"
GUI OPTIONAL FILENAME_MUSTEXIST OGCGEOPACKAGE_OUT_DATASET_TEMPLATE_OGCGEOPACKAGE_3 GeoPackage_Files(*.gpkg)|*.gpkg|All_files(*)|* Template File:
GUI LOOKUP OGCGEOPACKAGE_OUT_DATASET_TEMPLATE_OGCGEOPACKAGE_3 <Unused>, 
DEFAULT_MACRO OGCGEOPACKAGE_OUT_FME_GROUP_NAMED1_OGCGEOPACKAGE_3 
GUI OPTIONAL DISCLOSUREGROUP OGCGEOPACKAGE_OUT_FME_GROUP_NAMED1_OGCGEOPACKAGE_3 OGCGEOPACKAGE_OUT_VERSION_OGCGEOPACKAGE_3 Writer Parameters
DEFAULT_MACRO OGCGEOPACKAGE_OUT_VERSION_OGCGEOPACKAGE_3 1.2
OGCGEOPACKAGE_3_VERSION "$(OGCGEOPACKAGE_OUT_VERSION_OGCGEOPACKAGE_3)"
GUI CHOICE OGCGEOPACKAGE_OUT_VERSION_OGCGEOPACKAGE_3 1.0%1.1%1.2%1.3 Version:
DEFAULT_MACRO OGCGEOPACKAGE_OUT_SPATIAL_GROUP_OGCGEOPACKAGE_3 
GUI OPTIONAL DISCLOSUREGROUP OGCGEOPACKAGE_OUT_SPATIAL_GROUP_OGCGEOPACKAGE_3 OGCGEOPACKAGE_OUT_COORDINATE_SYSTEM_OGCGEOPACKAGE_3 Spatial
DEFAULT_MACRO OGCGEOPACKAGE_OUT_COORDINATE_SYSTEM_OGCGEOPACKAGE_3 
OGCGEOPACKAGE_3_COORDINATE_SYSTEM "$(OGCGEOPACKAGE_OUT_COORDINATE_SYSTEM_OGCGEOPACKAGE_3)"
GUI OPTIONAL COORDSYS OGCGEOPACKAGE_OUT_COORDINATE_SYSTEM_OGCGEOPACKAGE_3 Coordinate System:
DEFAULT_MACRO OGCGEOPACKAGE_OUT_GEOPACKAGE_WRT_ADV_PARM_OGCGEOPACKAGE_3 
GUI OPTIONAL DISCLOSUREGROUP OGCGEOPACKAGE_OUT_GEOPACKAGE_WRT_ADV_PARM_OGCGEOPACKAGE_3 OGCGEOPACKAGE_OUT_TRANSACTION_SIZE_OGCGEOPACKAGE_3%OGCGEOPACKAGE_OUT_ALWAYS_CREATE_FEATURE_TYPES_OGCGEOPACKAGE_3 Advanced
DEFAULT_MACRO OGCGEOPACKAGE_OUT_TRANSACTION_SIZE_OGCGEOPACKAGE_3 5000
OGCGEOPACKAGE_3_TRANSACTION_SIZE "$(OGCGEOPACKAGE_OUT_TRANSACTION_SIZE_OGCGEOPACKAGE_3)"
GUI INTEGER OGCGEOPACKAGE_OUT_TRANSACTION_SIZE_OGCGEOPACKAGE_3 Features Per Transaction:
DEFAULT_MACRO OGCGEOPACKAGE_OUT_ALWAYS_CREATE_FEATURE_TYPES_OGCGEOPACKAGE_3 NO
OGCGEOPACKAGE_3_ALWAYS_CREATE_FEATURE_TYPES "$(OGCGEOPACKAGE_OUT_ALWAYS_CREATE_FEATURE_TYPES_OGCGEOPACKAGE_3)"
GUI LOOKUP_CHOICE OGCGEOPACKAGE_OUT_ALWAYS_CREATE_FEATURE_TYPES_OGCGEOPACKAGE_3 YES,YES%NO,NO Always Create Tables
# ============================================================================
# Opt in for destination dataset type vs format type validation
DEFAULT_MACRO OGCGEOPACKAGE_OUT_DESTINATION_DATASETTYPE_VALIDATION_OGCGEOPACKAGE_3 Yes
OGCGEOPACKAGE_3_DESTINATION_DATASETTYPE_VALIDATION "$(OGCGEOPACKAGE_OUT_DESTINATION_DATASETTYPE_VALIDATION_OGCGEOPACKAGE_3)"
DEFAULT_MACRO OGCGEOPACKAGE_OUT_COORDINATE_SYSTEM_GRANULARITY_OGCGEOPACKAGE_3 FEATURE_TYPE
OGCGEOPACKAGE_3_COORDINATE_SYSTEM_GRANULARITY "$(OGCGEOPACKAGE_OUT_COORDINATE_SYSTEM_GRANULARITY_OGCGEOPACKAGE_3)"
DEFAULT_MACRO OGCGEOPACKAGE_OUT_ENCODE_FEATURE_TYPE_AND_ATTR_NAMES_OGCGEOPACKAGE_3 YES
OGCGEOPACKAGE_3_ENCODE_FEATURE_TYPE_AND_ATTR_NAMES "$(OGCGEOPACKAGE_OUT_ENCODE_FEATURE_TYPE_AND_ATTR_NAMES_OGCGEOPACKAGE_3)"
DEFAULT_MACRO OGCGEOPACKAGE_OUT_ENFORCE_GEOMETRY_COLUMN_CONSTRAINTS_OGCGEOPACKAGE_3 YES
OGCGEOPACKAGE_3_ENFORCE_GEOMETRY_COLUMN_CONSTRAINTS "$(OGCGEOPACKAGE_OUT_ENFORCE_GEOMETRY_COLUMN_CONSTRAINTS_OGCGEOPACKAGE_3)"
DEFAULT_MACRO OGCGEOPACKAGE_OUT_EXPOSE_PRIMARY_KEY_ATTRIBUTE_OGCGEOPACKAGE_3 YES
OGCGEOPACKAGE_3_EXPOSE_PRIMARY_KEY_ATTRIBUTE "$(OGCGEOPACKAGE_OUT_EXPOSE_PRIMARY_KEY_ATTRIBUTE_OGCGEOPACKAGE_3)"
DEFAULT_MACRO OGCGEOPACKAGE_OUT_WRITE_NULLS_OGCGEOPACKAGE_3 YES
OGCGEOPACKAGE_3_WRITE_NULLS "$(OGCGEOPACKAGE_OUT_WRITE_NULLS_OGCGEOPACKAGE_3)"
