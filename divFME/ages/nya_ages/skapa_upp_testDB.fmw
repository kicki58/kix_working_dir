MACRO SQLExecutor_DIRECTIVES CA_CERTIFICATE "" CLIENT_CERTIFICATE "" CLIENT_PRIV_KEY "" CREATE_FEATURE_TABLES_FROM_DATA Yes DISABLE_COLLECTION_SPLITTING yes HOST "$(server)" PASSWORD fme_decrypt() PORT "$(port)" QUERY_FEATURE_TYPES_FOR_MERGE_FILTERS Yes READ_TIME_WITH_TIMEZONE Yes SCHEMAS_FOR_TABLE_LISTING "" SSL_OPTIONS "" SSL_PASSWORD "" SSLMODE prefer USE_TRUE_POSTGIS_TYPES yes USER_NAME postgres
FACTORY_DEF {*} QueryFactory    FACTORY_NAME { SQLExecutor }    INPUT  FEATURE_TYPE SystemCaller_2_OUTPUT    QUERY_SQL            { "FME_SQL_DELIMITER<space><semicolon><lf>CREATE<space>SCHEMA<space>common<semicolon><lf>CREATE<space>SCHEMA<space>agestest<semicolon>" }    READER_TYPE          { POSTGIS }    READER_DATASET       { "ages_test" }    COMBINE_ATTRIBUTES   { RESULT_ONLY }    IGNORE_NULLS         { <Unused> }    COMBINE_GEOMETRY     { QUERY_ONLY }    QUERYFCT_OUTPUT      { "BASED_ON_CONNECTIONS" }    CONTINUE_ON_READER_ERROR YES    QUERYFCT_PROPAGATE_IDS_ON_SQL_EXECUTE YES    READER_PARAMS        { $(SQLExecutor_DIRECTIVES) }    OUTPUT { QUERY FEATURE_TYPE SQLExecutor_INITIATOR            }
# -------------------------------------------------------------------------
FACTORY_DEF {*} TeeFactory    FACTORY_NAME { ListBuilder_fme_type_remover }    INPUT  FEATURE_TYPE text_line_TEXTLINE_1    OUTPUT { FEATURE_TYPE ListBuilder_no_fme_type       @RemoveAttributes(fme_type,fme_geometry) }
FACTORY_DEF {*} ListFactory    FACTORY_NAME { ListBuilder }    INPUT { FEATURE_TYPE ListBuilder_no_fme_type }    LIST_NAME { "_list" }    LIST_ATTRS_TO_INCLUDE { text_line_data }    LIST_ATTRS_TO_INCLUDE_MODE { SELECTED }    GROUP_BY { fme_feature_type }    FLUSH_WHEN_GROUPS_CHANGE { No }    OUTPUT { LIST FEATURE_TYPE ListBuilder_OUTPUT          }
# -------------------------------------------------------------------------
# Create a FME_UUID_SAFE from the FME_UUID so we can use it for Tcl identifiers (FMEDESKTOP-11308)
INCLUDE [ FME_CleanseFMEUUID {ListConcatenator_2_c29a73ea_3454_4b16_b281_9018d39ac69810} ]
Tcl2 set $(FME_UUID_SAFE)__separator [FME_DecodeText {}];      regsub -all \"{}\" [FME_DecodeText {_list<opencurly><closecurly>.text_line_data}] [FME_DecodeText {<opencurly><backslash>d+<closecurly>}] $(FME_UUID_SAFE)__listPattern;      set $(FME_UUID_SAFE)__listPattern ^$$(FME_UUID_SAFE)__listPattern$;
Tcl2 proc $(FME_UUID_SAFE)__Concatenate {} {   upvar \#0 $(FME_UUID_SAFE)__separator separator             $(FME_UUID_SAFE)__listPattern listPattern;   set allAttrs [lsort -dictionary [FME_AttributeNames]];   set keepEmptyParts [string equal {No} {No}];   set result {};   foreach attrName $allAttrs {     if {[regexp $listPattern $attrName]} {       set attrValue [FME_GetAttribute $attrName];       if {$keepEmptyParts || $attrValue != {}} {         lappend result $attrValue;       };     };   };   FME_SetAttribute [FME_DecodeText {"_concatenated"}] [join $result $separator]; }
FACTORY_DEF {*} TeeFactory    FACTORY_NAME { ListConcatenator_2 }    INPUT  FEATURE_TYPE ListBuilder_OUTPUT    OUTPUT { FEATURE_TYPE ListConcatenator_2_OUTPUT         @Tcl2($(FME_UUID_SAFE)__Concatenate)          }
# -------------------------------------------------------------------------
FACTORY_DEF {*} AttrSetFactory    COMMAND_PARM_EVALUATION SINGLE_PASS    FACTORY_NAME { AttributeManager_2 }    INPUT  FEATURE_TYPE ListConcatenator_2_OUTPUT    MULTI_FEATURE_MODE { NO }    NULL_ATTR_MODE { NO_OP }    ATTRSET_CREATE_DIRECTIVES _PROPAGATE_MISSING_FDIV    ACTION_COLUMN 4    DEF_VAL_COLUMN 2    NUM_OF_COLUMNS 5    MISSING_INPUT_ATTR_HANDLING RENAME_SET_VALUE REMOVE    ATTR_ACTION { "_list<opencurly><closecurly>.text_line_data" "_list<opencurly><closecurly>.text_line_data" "" "buffer" "NO_OP" }      ATTR_ACTION { "_concatenated" "_concatenated" "" "buffer" "NO_OP" }      ATTR_ACTION { "" "ett" "<at>ReplaceString<openparen><at>Value<openparen>_concatenated<closeparen><comma><tab><comma><lf><space><comma>caseSensitive=TRUE<closeparen>" "varchar<openparen>200<closeparen>" "SET_TO" }      ATTR_ACTION { "" "tv<u00e5>" "<at>ReplaceString<openparen><at>Value<openparen>ett<closeparen><comma>agestest.<comma>agestest<quote>.<quote><comma>caseSensitive=TRUE<closeparen>" "varchar<openparen>200<closeparen>" "SET_TO" }      ATTR_ACTION { "" "tre" "<at>ReplaceString<openparen><at>Value<openparen>tv<u00e5><closeparen><comma>common.<comma>common<quote>.<quote><comma>caseSensitive=TRUE<closeparen>" "varchar<openparen>200<closeparen>" "SET_TO" }      ATTR_ACTION { "" "fyra" "<at>ReplaceString<openparen><at>Value<openparen>tre<closeparen><comma>BLOB<comma>geometry<comma>caseSensitive=TRUE<closeparen>" "varchar<openparen>200<closeparen>" "SET_TO" }      ATTR_ACTION { "" "sql_create" "FME_SQL_DELIMITER<space><semicolon><lf><at>Value<openparen>fyra<closeparen>" "varchar<openparen>200<closeparen>" "SET_TO" }    OUTPUT { OUTPUT FEATURE_TYPE AttributeManager_2_OUTPUT        }
