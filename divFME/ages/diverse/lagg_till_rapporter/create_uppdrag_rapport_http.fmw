FACTORY_DEF * TeeFactory   FACTORY_NAME "JSONFragmenter_5 <REJECTED> Transformer Output Nuker"   INPUT FEATURE_TYPE JSONFragmenter_5_<REJECTED>
# -------------------------------------------------------------------------
FACTORY_DEF {*} TestFactory    FACTORY_NAME { Tester_2 }    INPUT  FEATURE_TYPE JSONFragmenter_5_FRAGMENTS    TEST { "@EvaluateExpression(FDIV,STRING_ENCODED,<at>Value<openparen>name<closeparen>,Tester_2)" = kontext_uri ENCODED } CASE_INSENSITIVE_TEST { "@EvaluateExpression(FDIV,STRING_ENCODED,<at>Value<openparen>value<closeparen>,Tester_2)" CONTAINS arkeologisktuppdrag ENCODED }    BOOLEAN_OPERATOR { COMPOSITE }    COMPOSITE_TEST_EXPR { "1 AND 2" }    PRESERVE_FEATURE_ORDER { PER_OUTPUT_PORT }    OUTPUT { PASSED FEATURE_TYPE Tester_2_PASSED         }
# -------------------------------------------------------------------------
FACTORY_DEF {*} AttrSetFactory    COMMAND_PARM_EVALUATION SINGLE_PASS    FACTORY_NAME { AttributeManager }    INPUT  FEATURE_TYPE Tester_2_PASSED    MULTI_FEATURE_MODE { NO }    NULL_ATTR_MODE { NO_OP }    ATTRSET_CREATE_DIRECTIVES _PROPAGATE_MISSING_FDIV    ACTION_COLUMN 4    DEF_VAL_COLUMN 2    NUM_OF_COLUMNS 5    MISSING_INPUT_ATTR_HANDLING RENAME_SET_VALUE REMOVE    ATTR_ACTION { "_multipart_headers<opencurly><closecurly>.name" "_multipart_headers<opencurly><closecurly>.name" "" "buffer" "NO_OP" }      ATTR_ACTION { "_multipart_headers<opencurly><closecurly>.value" "_multipart_headers<opencurly><closecurly>.value" "" "buffer" "NO_OP" }      ATTR_ACTION { "_response_body" "_response_body" "" "buffer" "NO_OP" }      ATTR_ACTION { "_http_status_code" "_http_status_code" "" "buffer" "NO_OP" }      ATTR_ACTION { "json_type" "json_type" "" "buffer" "NO_OP" }      ATTR_ACTION { "json_index" "json_index" "" "uint32" "NO_OP" }      ATTR_ACTION { "name" "name" "" "varchar<openparen>200<closeparen>" "NO_OP" }      ATTR_ACTION { "value" "value" "" "varchar<openparen>200<closeparen>" "NO_OP" }      ATTR_ACTION { "uri" "uri_fromRAA" "" "varchar<openparen>255<closeparen>" "RENAME_SET_VALUE" }      ATTR_ACTION { "" "uuid-rapport" "<at>Substring<openparen><at>Value<openparen>uri_fromRAA<closeparen><comma><space>33<comma>36<closeparen>" "varchar<openparen>200<closeparen>" "SET_TO" }      ATTR_ACTION { "" "uuid-uppdrag" "<at>Substring<openparen><at>Value<openparen>value<closeparen><comma><space>49<comma>36<closeparen>" "varchar<openparen>200<closeparen>" "SET_TO" }      ATTR_ACTION { "fme_basename" "fme_basename" "" "varchar<openparen>50<closeparen>" "NO_OP" }    OUTPUT { OUTPUT FEATURE_TYPE AttributeManager_OUTPUT        }
# -------------------------------------------------------------------------
FACTORY_DEF {*} AttributeKeeperFactory    FACTORY_NAME { AttributeKeeper_2 }    INPUT  FEATURE_TYPE AttributeManager_OUTPUT    KEEP_ATTRS { uuid-rapport,uuid-uppdrag,uri_fromRAA }    KEEP_LISTS {  }    KEEP_FME_ATTRIBUTES Yes    BUILD_FEATURE_TABLES { NO }    OUTPUT_ON_ATTRIBUTE_CHANGE { <Unused> }    OUTPUT { OUTPUT FEATURE_TYPE AttributeKeeper_2_OUTPUT        }
