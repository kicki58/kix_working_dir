#! START_DEST_HEADER POSTGRES POSTGRES_2
DEFAULT_MACRO DestDataset_POSTGRES_2 $(DestDataset_POSTGRES)
GUI NAMED_DB_CONNECTION_ENCODED DestDataset_POSTGRES_2 FMT:POSTGRES Connection:
DEFAULT_MACRO POSTGRES_OUT_STRICT_TEMPORAL_TYPE_HANDLING_POSTGRES_2 Yes
POSTGRES_2_STRICT_TEMPORAL_TYPE_HANDLING "$(POSTGRES_OUT_STRICT_TEMPORAL_TYPE_HANDLING_POSTGRES_2)"
DEFAULT_MACRO POSTGRES_OUT_FME_CONNECTION_GROUP_POSTGRES_2 
GUI OPTIONAL DISCLOSUREGROUP POSTGRES_OUT_FME_CONNECTION_GROUP_POSTGRES_2 POSTGRES_OUT_NAMED_CONNECTION Database Connection
DEFAULT_MACRO POSTGRES_OUT_ADVANCED_POSTGRES_2 
GUI OPTIONAL DISCLOSUREGROUP POSTGRES_OUT_ADVANCED_POSTGRES_2 POSTGRES_OUT_BULK_COPY_POSTGRES_2%POSTGRES_OUT_ALWAYS_CREATE_FEATURE_TYPES_POSTGRES_2%POSTGRES_OUT_MISSING_ATTRIBUTE_BEHAVIOUR_POSTGRES_2%POSTGRES_OUT_START_TRANSACTION_POSTGRES_2%POSTGRES_OUT_TRANSACTION_INTERVAL_POSTGRES_2%POSTGRES_OUT_BEGIN_SQL_POSTGRES_2%POSTGRES_OUT_END_SQL_POSTGRES_2 Advanced
DEFAULT_MACRO POSTGRES_OUT_BULK_COPY_POSTGRES_2 YES
POSTGRES_2_BULK_COPY "$(POSTGRES_OUT_BULK_COPY_POSTGRES_2)"
GUI ACTIVECHOICE_LOOKUP POSTGRES_OUT_BULK_COPY_POSTGRES_2 YES,YES,POSTGRES_OUT_MISSING_ATTRIBUTE_BEHAVIOUR_POSTGRES_2%NO,NO Bulk Insert
# This keyword determines whether we enable creating tables when only
# receiving a schema feature or not receiving any data.
DEFAULT_MACRO POSTGRES_OUT_ALWAYS_CREATE_FEATURE_TYPES_POSTGRES_2 NO
POSTGRES_2_ALWAYS_CREATE_FEATURE_TYPES "$(POSTGRES_OUT_ALWAYS_CREATE_FEATURE_TYPES_POSTGRES_2)"
GUI LOOKUP_CHOICE POSTGRES_OUT_ALWAYS_CREATE_FEATURE_TYPES_POSTGRES_2 YES,YES%NO,NO Always Create Tables
DEFAULT_MACRO POSTGRES_OUT_MISSING_ATTRIBUTE_BEHAVIOUR_POSTGRES_2 <Unused>
POSTGRES_2_MISSING_ATTRIBUTE_BEHAVIOUR "$(POSTGRES_OUT_MISSING_ATTRIBUTE_BEHAVIOUR_POSTGRES_2)"
GUI LOOKUP_CHOICE POSTGRES_OUT_MISSING_ATTRIBUTE_BEHAVIOUR_POSTGRES_2 Insert<space>column<space>default<space>value,default%Insert<space>null,null Missing Attribute Behavior:
DEFAULT_MACRO POSTGRES_OUT_START_TRANSACTION_POSTGRES_2 0
POSTGRES_2_START_TRANSACTION "$(POSTGRES_OUT_START_TRANSACTION_POSTGRES_2)"
GUI TEXT POSTGRES_OUT_START_TRANSACTION_POSTGRES_2 Starting Feature:
DEFAULT_MACRO POSTGRES_OUT_TRANSACTION_INTERVAL_POSTGRES_2 1000
POSTGRES_2_TRANSACTION_INTERVAL "$(POSTGRES_OUT_TRANSACTION_INTERVAL_POSTGRES_2)"
GUI TEXT POSTGRES_OUT_TRANSACTION_INTERVAL_POSTGRES_2 Features Per Transaction
DEFAULT_MACRO POSTGRES_OUT_BEGIN_SQL_POSTGRES_2 
POSTGRES_2_BEGIN_SQL "$(POSTGRES_OUT_BEGIN_SQL_POSTGRES_2)"
GUI OPTIONAL TEXT_EDIT_SQL_CFG POSTGRES_OUT_BEGIN_SQL_POSTGRES_2 MODE,SQL;FORMAT,POSTGRES SQL To Run Before Write
DEFAULT_MACRO POSTGRES_OUT_END_SQL_POSTGRES_2 
POSTGRES_2_END_SQL "$(POSTGRES_OUT_END_SQL_POSTGRES_2)"
GUI OPTIONAL TEXT_EDIT_SQL_CFG POSTGRES_OUT_END_SQL_POSTGRES_2 MODE,SQL;FORMAT,POSTGRES SQL To Run After Write
DEFAULT_MACRO POSTGRES_OUT_COORDINATE_SYSTEM_GRANULARITY_POSTGRES_2 FEATURE
POSTGRES_2_COORDINATE_SYSTEM_GRANULARITY "$(POSTGRES_OUT_COORDINATE_SYSTEM_GRANULARITY_POSTGRES_2)"
# ============================================================================
POSTGRES_2_GENERATE_FME_BUILD_NUM 25835
POSTGRES_2_DATASET "$(DestDataset_POSTGRES_2)"
