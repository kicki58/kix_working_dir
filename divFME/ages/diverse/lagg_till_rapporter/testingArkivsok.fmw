FACTORY_DEF {*} AttrSetFactory    COMMAND_PARM_EVALUATION SINGLE_PASS    FACTORY_NAME { AttributeManager_5 }    INPUT  FEATURE_TYPE ListExploder_ELEMENTS    MULTI_FEATURE_MODE { NO }    NULL_ATTR_MODE { NO_OP }    ATTRSET_CREATE_DIRECTIVES _PROPAGATE_MISSING_FDIV    ACTION_COLUMN 4    DEF_VAL_COLUMN 2    NUM_OF_COLUMNS 5    MISSING_INPUT_ATTR_HANDLING RENAME_SET_VALUE REMOVE    ATTR_ACTION { "_list" "uri" "" "varchar<openparen>200<closeparen>" "RENAME_SET_VALUE" }      ATTR_ACTION { "_creation_instance" "_creation_instance" "" "uint64" "REMOVE" }      ATTR_ACTION { "stop" "stop" "" "varchar<openparen>200<closeparen>" "REMOVE" }      ATTR_ACTION { "start" "start" "" "varchar<openparen>200<closeparen>" "REMOVE" }      ATTR_ACTION { "_response_body" "_response_body" "" "buffer" "REMOVE" }      ATTR_ACTION { "_http_status_code" "_http_status_code" "" "buffer" "REMOVE" }      ATTR_ACTION { "_result" "_result" "" "buffer" "REMOVE" }      ATTR_ACTION { "_element_index" "_element_index" "" "uint32" "REMOVE" }    OUTPUT { OUTPUT FEATURE_TYPE AttributeManager_5_OUTPUT        }
