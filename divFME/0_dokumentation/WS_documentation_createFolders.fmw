Tcl2 set AttributeSplitter_9606a87b_dd9a_455a_a018_7dfd3d3c77184_splitDelim [FME_DecodeText {<backslash>}];      if { [regexp {^([1-9][0-9]*s)+$} [set AttributeSplitter_9606a87b_dd9a_455a_a018_7dfd3d3c77184_splitDelim]] }      {         set AttributeSplitter_9606a87b_dd9a_455a_a018_7dfd3d3c77184_splitWidths [split [regsub -all {s$} {<backslash>} {}] s];         proc AttributeSplitter_doSplit {}         {            global AttributeSplitter_9606a87b_dd9a_455a_a018_7dfd3d3c77184_splitWidths;            set source [FME_GetAttribute [FME_DecodeText {folders}]];            set attrNum 0;            set listName [FME_DecodeText {folder_level}];            set attrPos 0;            set keepEmptyParts [string equal {Yes} {No}];            foreach width [set AttributeSplitter_9606a87b_dd9a_455a_a018_7dfd3d3c77184_splitWidths]            {               set endPos [expr $attrPos + $width - 1];               set bit [string range $source $attrPos $endPos];               set part [string trim $bit];               if { $keepEmptyParts || $part != \"\" } {                  FME_SetAttribute "$listName{$attrNum}" $part;                  incr attrNum;               };               incr attrPos $width;            };         };      }      else      {         proc AttributeSplitter_doSplit {}         {            global AttributeSplitter_9606a87b_dd9a_455a_a018_7dfd3d3c77184_splitDelim;            set delim [set AttributeSplitter_9606a87b_dd9a_455a_a018_7dfd3d3c77184_splitDelim];            set delimLength [string length $delim];            set source [FME_GetAttribute [FME_DecodeText {folders}]];            set keepEmptyParts [string equal {Yes} {No}];            set bits {};            set startIndex 0;            set nextIndex [string first $delim $source $startIndex];            while {$nextIndex >= 0} {              lappend bits [string range $source $startIndex [expr $nextIndex-1]];              set startIndex [expr $nextIndex + $delimLength];              set nextIndex [string